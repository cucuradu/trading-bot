# Copy this file to .env and fill in your credentials.
# .env is gitignored and must NEVER be committed.
# In cloud routines, set these as environment variables on the routine itself —
# do NOT create a .env file in the cloud.

# ---- Alpaca (PAPER trading by default) ----
ALPACA_ENDPOINT=https://paper-api.alpaca.markets/v2
ALPACA_DATA_ENDPOINT=https://data.alpaca.markets/v2
ALPACA_API_KEY=your_alpaca_paper_api_key_here
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key_here

# Live-trading failsafe override. Leave UNSET (or =0) during paper phase.
# Setting this to 1 disables the live-endpoint refusal in scripts/alpaca.sh.
# ALLOW_LIVE_TRADING=1

# ---- Gemini (research, free tier) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional override for --smart calls (synthesis + critique + historical-analog).
# Defaults to gemini-2.5-pro if unset.
# GEMINI_SMART_MODEL=gemini-2.5-pro

# ---- Multi-source news adapters (all optional; missing keys → empty results) ----
# NewsAPI.org — free tier 100 requests/day. Sign up: https://newsapi.org/register
NEWS_API_KEY=
# Finnhub — free tier 60 requests/min. Sign up: https://finnhub.io/register
FINNHUB_KEY=
# SEC EDGAR fair-use header — required by SEC, format: "Your Name <email>"
EDGAR_USER_AGENT=

# ---- WhatsApp notifications via CallMeBot (free, personal use) ----
# Setup: from your phone, message +34 621 331 709 with text:
#   "I allow callmebot to send me messages"
# The bot replies with your API key. Use your full phone number with country code, no '+'.
WHATSAPP_PHONE=40712345678
WHATSAPP_APIKEY=your_callmebot_apikey_here
